# Application
APP_NAME=Factory WMS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=postgresql+asyncpg://wms_user:wms_password@localhost:5432/wms_db
DATABASE_URL_SYNC=postgresql://wms_user:wms_password@localhost:5432/wms_db

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# First Admin User
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_EMAIL=admin@factory.local
